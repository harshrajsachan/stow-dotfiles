#mod key
set $mod Mod4
set $refresh_i3status killall -SIGUSR1 i3status

#font
font pango:jet brains nerd mono 8

#important startup
exec --no-startup-id dex --autostart --environment i3

#picom compositor
exec_always --no-startup-id picom --backend glx --config ~/.config/picom/picom.conf

#autotiling
exec_always --no-startup-id autotiling

#Polybar and Bind to close polybar
exec_always --no-startup-id sh -c "killall -q polybar; sleep 1; polybar main &"
bindsym --release $mod+Shift+p exec --no-startup-id ~/.config/i3/scripts/polybar_toggle.sh

#Wallpaper
exec_always --no-startup-id feh --bg-fill ~/Pictures/1.jpg
bindsym Mod1+Shift+w exec ~/.config/i3/scripts/wall_toggle.sh

#Screenshot Bind
bindsym Mod1+s exec --no-startup-id flameshot gui -p ~/Screenshots -c

#redshift
exec_always --no-startup-id pkill redshift; redshift -O 4000 -P
bindsym $mod+Shift+Up exec "redshift -O 4000"
bindsym $mod+Shift+Down exec "redshift -x"

#dunst
exec_always --no-startup-id killall dunst; dunst

#capskey - escape
exec_always --no-startup-id setxkbmap -option caps:escape

#to connect from my phone with pc
#exec_always --no-startup-id kdeconnectd

#to store password
exec_always --no-startup-id /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1

#cursor
exec --no-startup-id xsetroot -cursor_name left_ptr
exec_always --no-startup-id xrdb -merge ~/.Xresources

#touchpad-toggle
bindsym --release F12 exec ~/.config/i3/scripts/touchpad-toggle.sh

#Auto mute
bindsym --release $mod+Shift+m exec ~/.config/i3/scripts/auto_mute.sh

#mouse pad setting
exec_always xinput set-prop 16 "libinput Tapping Enabled" 1
exec_always --no-startup-id xinput set-prop 16 "libinput Natural Scrolling Enabled" 1

# i3 lock
exec --no-startup-id sh -c "sleep 1 && ~/.config/i3/scripts/lock.sh"
exec --no-startup-id xidlehook \
  --not-when-audio \
  --not-when-fullscreen \
  --timer 300 '~/.config/i3/scripts/lock.sh' ''
bindsym --release $mod+Shift+x exec --no-startup-id ~/.config/i3/scripts/lock.sh

#emoji
bindsym Mod1+Shift+e exec --no-startup-id rofi -show emoji

#ScratchPad
bindsym --release $mod+Shift+minus move scratchpad
bindsym --release $mod+minus scratchpad show
for_window [title="scratchpad"] floating enable, resize set 800 500, move position center
for_window [title="scratchpad"] move scratchpad

#bluetooth
bindsym --release $mod+shift+b exec --no-startup-id ~/.config/i3/scripts/bt-toggle.sh

#mpd music player
exec --no-startup-id ~/.config/i3/scripts/mpd_boot_fix.sh
bindsym --release F8 exec --no-startup-id /home/harsh/.config/i3/scripts/mpd.sh toggle
bindsym --release F5 exec --no-startup-id /home/harsh/.config/i3/scripts/mpd.sh prev
bindsym --release F6 exec --no-startup-id /home/harsh/.config/i3/scripts/mpd.sh next
bindsym --release Shift+F9 exec --no-startup-id /home/harsh/.config/i3/scripts/mpd.sh stop
bindsym --release F9 exec --no-startup-id /home/harsh/.config/i3/scripts/mpd.sh update
bindsym --release Mod1+Shift+f exec --no-startup-id /home/harsh/.config/i3/scripts/mpd.sh fav
bindsym --release Mod1+Shift+d exec --no-startup-id /home/harsh/.config/i3/scripts/mpd.sh trash
bindsym --release F7 exec --no-startup-id /home/harsh/.config/i3/scripts/mpd.sh cycle
bindsym --release Shift+F7 exec --no-startup-id /home/harsh/.config/i3/scripts/mpd.sh cycle_prev
bindsym --release Shift+F6 exec --no-startup-id /home/harsh/.config/i3/scripts/mpd.sh forward
bindsym --release Shift+F5 exec --no-startup-id /home/harsh/.config/i3/scripts/mpd.sh backward
bindsym --release Shift+F8 exec --no-startup-id /home/harsh/.config/i3/scripts/mpd.sh repeat_one

# reload the configuration file
bindsym --release $mod+Shift+c reload

# restart i3 inplace (preserves your layout/session, can be used to upgrade i3)
bindsym --release $mod+Shift+r restart


#Windows Setting and Colours
default_border pixel 2
default_floating_border pixel 2
gaps inner 4 
gaps outer 5    
smart_gaps off
smart_borders on


# Focused window (ACTIVE TAB)
client.focused          $red $red #ffffff $red $red
client.unfocused        #111111 #111111 #444444 #111111 #111111
client.focused_inactive #111111 #111111 #aaaaaa #111111 #111111
client.urgent           $red      $red      $white    $red      $red

# Base colors
set $bg         #000000
set $bg-alt     #111111
set $red        #ff2e2e
set $red-dark   #cc1f1f
set $white      #e0e0e0
set $gray       #444444


#Volume binds
bindsym F2 exec pactl set-sink-volume @DEFAULT_SINK@ -5%
bindsym F3 exec pactl set-sink-volume @DEFAULT_SINK@ +5%
bindsym F4 exec pactl set-sink-mute @DEFAULT_SINK@ toggle
#Brightness binds
bindsym Mod1+F2 exec brightnessctl set 5%-
bindsym Mod1+F3 exec brightnessctl set +5%

# Use Mouse+$mod to drag floating windows to their wanted position
floating_modifier $mod

# move tiling windows via drag & drop by left-clicking into the title bar,
tiling_drag modifier titlebar

# start a terminal
bindsym --release Mod1+t exec kitty
bindsym --release Mod1+Shift+t exec alacritty

# kill focused window
bindsym --release $mod+Shift+q kill

# start dmenu (a program launcher)
bindsym --release $mod+d exec rofi -show drun

# change focus
bindsym --release $mod+h focus left
bindsym --release $mod+j focus down
bindsym --release $mod+k focus up
bindsym --release $mod+l focus right

# alternatively, you can use the cursor keys:
#bindsym $mod+Left focus left
#bindsym $mod+Down focus down
#bindsym $mod+Up focus up
#bindsym $mod+Right focus right

# move focused window
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# alternatively, you can use the cursor keys:
#bindsym $mod+Shift+Left move left
#bindsym $mod+Shift+Down move down
#bindsym $mod+Shift+Up move up
#bindsym $mod+Shift+Right move right

# split in horizontal orientation
bindsym --release $mod+b split h

# split in vertical orientation
bindsym --release $mod+v split v

# enter fullscreen mode for the focused container
bindsym --release $mod+f fullscreen toggle

# change container layout (stacked, tabbed, toggle split)
bindsym --release $mod+s layout stacking
bindsym --release $mod+w layout tabbed
bindsym --release $mod+e layout toggle split

# toggle tiling / floating
bindsym --release $mod+shift+space floating toggle,resize set 800 500,move position center
# change focus between tiling / floating windows
bindsym --release $mod+space focus mode_toggle
for_window [floating] resize set 70 ppt 50 ppt move position center



# focus the parent container
bindsym --release $mod+a focus parent

# focus the child container
bindsym --release $mod+c focus child

# We use variables to avoid repeating the names in multiple places.
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

# switch to workspace
bindsym --release $mod+1 workspace number $ws1
bindsym --release $mod+2 workspace number $ws2
bindsym --release $mod+3 workspace number $ws3
bindsym --release $mod+4 workspace number $ws4
bindsym --release $mod+5 workspace number $ws5
bindsym --release $mod+6 workspace number $ws6
bindsym --release $mod+7 workspace number $ws7
bindsym --release $mod+8 workspace number $ws8
bindsym --release $mod+9 workspace number $ws9
bindsym --release $mod+0 workspace number $ws10

# move focused container to workspace
bindsym --release $mod+Shift+1 move container to workspace number $ws1
bindsym --release $mod+Shift+2 move container to workspace number $ws2
bindsym --release $mod+Shift+3 move container to workspace number $ws3
bindsym --release $mod+Shift+4 move container to workspace number $ws4
bindsym --release $mod+Shift+5 move container to workspace number $ws5
bindsym --release $mod+Shift+6 move container to workspace number $ws6
bindsym --release $mod+Shift+7 move container to workspace number $ws7
bindsym --release $mod+Shift+8 move container to workspace number $ws8
bindsym --release $mod+Shift+9 move container to workspace number $ws9
bindsym --release $mod+Shift+0 move container to workspace number $ws10

# move focused window and swap to that screen
bindsym --release $mod+Ctrl+1 move container to workspace $ws1; workspace $ws1
bindsym --release $mod+Ctrl+2 move container to workspace $ws2; workspace $ws2
bindsym --release $mod+Ctrl+3 move container to workspace $ws3; workspace $ws3
bindsym --release $mod+Ctrl+4 move container to workspace $ws4; workspace $ws4
bindsym --release $mod+Ctrl+5 move container to workspace $ws5; workspace $ws5
bindsym --release $mod+Ctrl+6 move container to workspace $ws6; workspace $ws6
bindsym --release $mod+Ctrl+7 move container to workspace $ws7; workspace $ws7
bindsym --release $mod+Ctrl+8 move container to workspace $ws8; workspace $ws8
bindsym --release $mod+Ctrl+9 move container to workspace $ws9; workspace $ws9
bindsym --release $mod+Ctrl+0 move container to workspace $ws10; workspace $ws10

#toggle workspace script
bindsym --release $mod+Tab exec --no-startup-id ~/.config/i3/scripts/toggle_ws1.sh
bindsym --release $mod+grave exec --no-startup-id ~/.config/i3/scripts/toggle_ws2.sh
#next and previous workspace
bindsym --release $mod+n workspace next
bindsym --release $mod+p workspace prev

#resizing
bindsym $mod+Ctrl+h resize grow width 10 px or 5 ppt
bindsym $mod+Ctrl+j resize shrink height 10 px or 5 ppt
bindsym $mod+Ctrl+k resize grow height 10 px or 5 ppt
bindsym $mod+Ctrl+l resize shrink width 10 px or 5 ppt


bindsym $mod+Left resize grow width 1  px or 1 ppt 
bindsym $mod+Down resize shrink height 1 px or 1 ppt  
bindsym $mod+Up resize grow height 1 px or 1 ppt
bindsym $mod+Right resize shrink width 1 px or 1 ppt   


#MY Application binds
bindsym --release Mod1+b exec helium-browser
bindsym --release Mod1+Shift+b exec helium-browser --incognito
bindsym --release Mod1+e exec kitty -e yazi
bindsym --release Mod1+Shift+l exec kitty -e nvim +"Leet"
bindsym --release F10 exec thunderbird
bindsym --release Mod1+r exec localsend
bindsym --release Mod1+4 exec alacritty -e toofan
bindsym --release Mod1+d exec alacritty -e discordo
bindsym --release Mod1+q exec kitty -e btop
bindsym --release $mod+Shift+s exec --no-startup-id ~/.config/i3/scripts/ss_window.sh

#Code Editors
bindsym --release Mod1+0 exec code
bindsym --release Mod1+8 exec antigravity
bindsym --release Mod1+9 exec cursor
bindsym --release Mod1+n exec kitty -e nvim
bindsym --release Mod1+v exec kitty -e vim ~/Notes/todo

#PWA binds
bindsym --release Mod1+1 exec helium-browser --app="https://monkeytype.com"
bindsym --release Mod1+2 exec helium-browser --app="https://keybr.com"
bindsym --release Mod1+3 exec helium-browser --app="https://www.typingclub.com"
bindsym --release Mod1+c exec helium-browser --app="https://chatgpt.com"
bindsym --release Mod1+Shift+c exec helium-browser --app="https://lichess.org/"
bindsym --release Mod1+a exec helium-browser --app="https://9anime.org.lv/bookmark/"
bindsym --release Mod1+Shift+n exec helium-browser --app="https://net20.cc"
bindsym --release Mod1+y exec helium-browser --app="https://youtube.com"
bindsym --release Mod1+z exec helium-browser --app="https://leetcode.com/problemset"
bindsym --release Mod1+g exec helium-browser --app="https://mail.proton.me/u/0/inbox"


#Assig Apps to Window
bindsym --release Mod1+w exec ~/.config/i3/scripts/whatsapp.sh
bindsym --release Mod1+Shift+a exec ~/.config/i3/scripts/applemusic.sh
for_window [class="Brave-browser" instance="music.apple.com"] move container to workspace "music"
for_window [class="Brave-browser" instance="web.whatsapp.com"] move container to workspace "whatsapp"


