[global]
monitor = 0
follow = mouse
width = 320
height = 300
offset = 15x40
origin = top-right
scale = 0

font = JetBrainsMono Nerd Font 10
line_height = 0
markup = full
format = "<b>%s</b>\n%b"

alignment = left
vertical_alignment = center

show_age_threshold = 60
word_wrap = yes
ellipsize = middle

idle_threshold = 120
ignore_newline = no
stack_duplicates = true
hide_duplicate_count = false

show_indicators = yes
icon_position = left

sticky_history = yes
history_length = 20

browser = firefox

always_run_script = true

frame_width = 2
separator_height = 2
padding = 10
horizontal_padding = 10

corner_radius = 10

transparency = 10

[urgency_low]
timeout = 4
background = "#111111"
foreground = "#aaaaaa"
frame_color = "#222222"

[urgency_normal]
timeout = 6
background = "#111111"
foreground = "#ffffff"
frame_color = "#ff0000"

[urgency_critical]
timeout = 0
background = "#111111"
foreground = "#ffffff"
frame_color = "#ff0000"
